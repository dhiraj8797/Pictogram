# Pictogram Email Service Configuration
# Copy this to .env and fill in your actual credentials

# SMTP Server Settings (Titan Email)
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=587
EMAIL_SECURE=false

# Email Authentication
EMAIL_USER=support@pictogram.online
EMAIL_PASS=your_email_password_here

# Sender Configuration
EMAIL_FROM=Pictogram <support@pictogram.online>

# App Configuration
APP_URL=https://pictogram.online

# Node Environment
NODE_ENV=development
